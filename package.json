{
  "name": "sbox-docs-mcp",
  "version": "0.2.0",
  "description": "MCP server for fetching s&box (Facepunch) documentation — search guides, read pages, and browse API references.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sbox-docs-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "sbox",
    "s&box",
    "facepunch",
    "documentation",
    "gamedev",
    "source2"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.24.0",
    "cheerio": "^1.0.0",
    "minisearch": "^7.0.0",
    "turndown": "^7.2.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.5",
    "typescript": "^5.7.0"
  }
}
